# SafeSignal app mode
NEXT_PUBLIC_DEMO_MODE=true
# Public origin for Vapi tool + webhook URLs (local dev or production URL)
APP_URL=http://localhost:3000

# InsForge app backend (copy oss_host from .insforge/project.json after `npx @insforge/cli link`)
# NEXT_PUBLIC_INSFORGE_URL is accepted as an alias for the base URL.
NEXT_PUBLIC_INSFORGE_BASE_URL=https://your-appkey.us-east.insforge.app
NEXT_PUBLIC_INSFORGE_ANON_KEY=your-insforge-anon-key
# Optional server writes if anon is restricted: npx @insforge/cli secrets get SERVICE_ROLE_KEY
INSFORGE_SERVICE_ROLE_KEY=your-insforge-service-role-key

# TinyFish Search + Fetch (same APIs as Cursor MCP project-0-safesignal-tinyfish)
# https://api.search.tinyfish.ai — https://api.fetch.tinyfish.ai
TINYFISH_API_KEY=sk-tinyfish-example

# Vapi — browser (web voice on /voice)
NEXT_PUBLIC_VAPI_PUBLIC_KEY=your-vapi-public-key
NEXT_PUBLIC_VAPI_ASSISTANT_ID=your-vapi-assistant-id
# Vapi — server (outbound calls, /api/vapi_config assistant fallback)
VAPI_API_KEY=your-vapi-server-key
VAPI_ASSISTANT_ID=your-vapi-assistant-id
VAPI_PHONE_NUMBER_ID=your-vapi-phone-number-id

# Ghost snapshot metadata (optional)
GHOST_DATABASE_ID=your-ghost-database-id
GHOST_FORK_ID=your-ghost-fork-id
