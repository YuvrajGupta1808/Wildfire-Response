# Fireworks AI API Key (required for GLM-5.1 coordinator)
FIREWORKS_API_KEY=your-fireworks-api-key-here

# Guild.ai — No API key needed!
# Auth is handled via browser-based OAuth:
#   npm install -g @guildai/cli
#   guild auth login          # opens browser to sign in at app.guild.ai
#   guild auth status         # verify: ✓ Authenticated
#   guild setup               # install skills for agent development
